{
  "name": "Java & Cucumber Lab",
  "image": "mcr.microsoft.com/vscode/devcontainers/java:17",
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-java-test",
        "vscjava.vscode-maven",
        "alexkrechik.cucumberautocomplete"
      ],
      "settings": {
        "cucumberautocomplete.steps": ["lab-02-cucumber/src/test/java/**/*.java"],
        "cucumberautocomplete.syncfeatures": "lab-02-cucumber/src/test/resources/**/*.feature"
      }
    }
  }
}